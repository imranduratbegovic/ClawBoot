#!/bin/sh
set -u

SETUP_ORIGIN=http://127.0.0.1:3210
STATUS_URL="$SETUP_ORIGIN/api/v1/status"
NODE=/opt/clawboot/runtime/bin/node
VERSION_FILE=/opt/clawboot/VERSION
EXPECTED_VERSION="$(cat "$VERSION_FILE" 2>/dev/null || true)"

service_ready() {
  [ -x "$NODE" ] && [ -n "$EXPECTED_VERSION" ] || return 1
  "$NODE" -e "fetch(process.argv[1], { signal: AbortSignal.timeout(1500) }).then(async (response) => { const body = await response.json(); process.exit(response.ok && body.serviceVersion === process.argv[2] ? 0 : 1); }).catch(() => process.exit(1));" \
    "$STATUS_URL" "$EXPECTED_VERSION" >/dev/null 2>&1
}

wait_for_service() {
  attempt=0
  while [ "$attempt" -lt 25 ]; do
    if service_ready; then
      return 0
    fi
    attempt=$((attempt + 1))
    sleep 0.4
  done
  return 1
}

show_error() {
  message="ClawBoot could not repair its local setup service. Open the latest ClawBoot package with Package Install again, then retry."
  if command -v zenity >/dev/null 2>&1; then
    zenity --error --title=ClawBoot --text="$message" >/dev/null 2>&1
  elif command -v xmessage >/dev/null 2>&1; then
    xmessage -center "$message" >/dev/null 2>&1
  elif command -v notify-send >/dev/null 2>&1; then
    notify-send "ClawBoot could not start" "$message" >/dev/null 2>&1
  fi
}

if ! wait_for_service; then
  if command -v pkexec >/dev/null 2>&1; then
    pkexec /opt/clawboot/bin/clawboot-repair >/dev/null 2>&1 || true
  fi
  if ! wait_for_service; then
    show_error
    exit 1
  fi
fi

for browser in chromium chromium-browser; do
  if command -v "$browser" >/dev/null 2>&1; then
    profile="${XDG_CONFIG_HOME:-$HOME/.config}/clawboot/browser"
    mkdir -p "$profile"
    exec "$browser" \
      --app="$SETUP_ORIGIN/?v=$EXPECTED_VERSION" \
      --class=io.openclaw.ClawBoot \
      --name=ClawBoot \
      --user-data-dir="$profile" \
      --incognito \
      --disable-extensions \
      --disable-sync \
      --no-first-run \
      --no-default-browser-check
  fi
done

for browser in firefox-esr firefox; do
  if command -v "$browser" >/dev/null 2>&1; then
    exec "$browser" --private-window "$SETUP_ORIGIN/?v=$EXPECTED_VERSION"
  fi
done

if command -v xdg-open >/dev/null 2>&1; then
  exec xdg-open "$SETUP_ORIGIN"
fi

if command -v gio >/dev/null 2>&1; then
  exec gio open "$SETUP_ORIGIN"
fi

show_error
exit 1
