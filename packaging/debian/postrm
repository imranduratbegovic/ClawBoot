#!/bin/sh
set -eu

systemctl daemon-reload >/dev/null 2>&1 || true
update-desktop-database /usr/share/applications >/dev/null 2>&1 || true
gtk-update-icon-cache -f -t /usr/share/icons/hicolor >/dev/null 2>&1 || true
case "${1:-}" in
  remove|purge|disappear|abort-install)
    rm -f /etc/sudoers.d/clawboot-agent-full-access
    ;;
  upgrade|failed-upgrade|abort-upgrade)
    # Keep Full Pi access across package upgrades. The new package revalidates it.
    ;;
esac

if [ "${1:-}" = purge ]; then
  # state.json can contain pairing approvals and setup credentials. Debian
  # purge must remove it; ordinary removal intentionally keeps resumable state.
  rm -rf /var/lib/clawboot
fi

# OpenClaw configuration and Ollama models are deliberately preserved so a
# reinstall does not require relinking accounts or redownloading the model.
exit 0
