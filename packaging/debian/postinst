#!/bin/sh
set -u

warn() {
  echo "ClawBoot installer warning: $*" >&2
}

case "${1:-}" in
  configure)
    if ! /opt/clawboot/bin/clawboot-repair; then
      warn "the first service restart did not finish; retrying once."
      sleep 2
      /opt/clawboot/bin/clawboot-repair || {
        warn "ClawBoot could not verify the upgraded background service."
        exit 1
      }
    fi

    update-desktop-database /usr/share/applications >/dev/null 2>&1 || true
    gtk-update-icon-cache -f -t /usr/share/icons/hicolor >/dev/null 2>&1 || true
    ;;
  *)
    # Rollback and abort invocations must not start a partially configured service.
    ;;
esac

exit 0
