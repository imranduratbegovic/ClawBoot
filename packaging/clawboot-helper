#!/bin/sh
set -eu

ACTION="${1:-}"
if [ "$#" -ne 1 ]; then
  echo "Exactly one allowlisted action is required." >&2
  exit 64
fi

export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
export DEBIAN_FRONTEND=noninteractive

OLLAMA_VERSION="0.31.2"
OLLAMA_ARCHIVE_URL="https://github.com/ollama/ollama/releases/download/v${OLLAMA_VERSION}/ollama-linux-arm64.tar.zst"
OLLAMA_ARCHIVE_SHA256="07a0adfcf3ed48ff110e2a3bcec897ca4d3f77d6f817d6ff63e83debfd102a31"

require_pi_arm64() {
  ARCH="$(uname -m)"
  case "$ARCH" in
    aarch64|arm64) ;;
    *)
      echo "Ollama setup requires a 64-bit ARM operating system; found $ARCH." >&2
      exit 65
      ;;
  esac

  if [ -r /proc/device-tree/model ] && ! tr -d '\000' < /proc/device-tree/model | grep -qi 'Raspberry Pi 5'; then
    echo "This installer only supports Raspberry Pi 5 hardware." >&2
    exit 65
  fi
}

prepare_system() {
  MISSING_PACKAGES=""
  [ -r /etc/ssl/certs/ca-certificates.crt ] || MISSING_PACKAGES="$MISSING_PACKAGES ca-certificates"
  command -v curl >/dev/null 2>&1 || MISSING_PACKAGES="$MISSING_PACKAGES curl"
  command -v git >/dev/null 2>&1 || MISSING_PACKAGES="$MISSING_PACKAGES git"
  command -v tar >/dev/null 2>&1 || MISSING_PACKAGES="$MISSING_PACKAGES tar"
  command -v zstd >/dev/null 2>&1 || MISSING_PACKAGES="$MISSING_PACKAGES zstd"

  if [ -z "$MISSING_PACKAGES" ]; then
    echo "Required Raspberry Pi OS tools are already installed."
    return 0
  fi

  echo "Installing the missing Raspberry Pi OS tools:$MISSING_PACKAGES"
  ATTEMPT=1
  while [ "$ATTEMPT" -le 3 ]; do
    if apt-get -o Acquire::Retries=3 -o DPkg::Lock::Timeout=120 update && \
      apt-get -o Acquire::Retries=3 -o DPkg::Lock::Timeout=120 install \
        -y --no-install-recommends $MISSING_PACKAGES; then
      return 0
    fi

    echo "Package setup attempt $ATTEMPT of 3 did not finish; repairing package state before retrying." >&2
    dpkg --configure -a || true
    apt-get -o Acquire::Retries=3 -o DPkg::Lock::Timeout=120 \
      --fix-broken install -y || true
    ATTEMPT=$((ATTEMPT + 1))
  done

  echo "Raspberry Pi OS could not install:$MISSING_PACKAGES" >&2
  echo "Check the internet connection and Raspberry Pi OS updates, then press Retry in ClawBoot." >&2
  exit 69
}

write_ollama_service() {
  if ! getent group ollama >/dev/null 2>&1; then
    groupadd --system ollama
  fi
  if ! id ollama >/dev/null 2>&1; then
    useradd --system --gid ollama --create-home \
      --home-dir /usr/share/ollama --shell /usr/sbin/nologin ollama
  fi
  install -d -o ollama -g ollama -m 0755 /usr/share/ollama
  install -d -m 0755 /etc/systemd/system

  SERVICE_TMP="$(mktemp)"
  trap 'rm -f "$SERVICE_TMP"' EXIT HUP INT TERM
  printf '%s\n' \
    '[Unit]' \
    'Description=Ollama Service' \
    'After=network-online.target' \
    'Wants=network-online.target' \
    '' \
    '[Service]' \
    'ExecStart=/usr/bin/ollama serve' \
    'User=ollama' \
    'Group=ollama' \
    'Restart=always' \
    'RestartSec=3' \
    'Environment="HOME=/usr/share/ollama"' \
    '' \
    '[Install]' \
    'WantedBy=multi-user.target' > "$SERVICE_TMP"
  install -o root -g root -m 0644 "$SERVICE_TMP" /etc/systemd/system/ollama.service
  rm -f "$SERVICE_TMP"
  trap - EXIT HUP INT TERM
}

install_ollama_arm64() {
  require_pi_arm64
  prepare_system

  ARCHIVE="$(mktemp --suffix=.tar.zst)"
  trap 'rm -f "$ARCHIVE"' EXIT HUP INT TERM
  echo "Downloading the official Ollama Linux arm64 archive."
  curl --fail --show-error --location --proto '=https' --tlsv1.2 \
    --connect-timeout 20 --retry 5 --retry-delay 3 --retry-all-errors \
    --output "$ARCHIVE" \
    "$OLLAMA_ARCHIVE_URL"
  echo "$OLLAMA_ARCHIVE_SHA256  $ARCHIVE" | sha256sum --check --status
  echo "Verified Ollama $OLLAMA_VERSION archive."
  echo "Installing Ollama into /usr."
  zstd --decompress --stdout "$ARCHIVE" | tar -xf - -C /usr
  rm -f "$ARCHIVE"
  trap - EXIT HUP INT TERM

  test -x /usr/bin/ollama
  write_ollama_service
  echo "Ollama arm64 installed."
}

configure_ollama_loopback() {
  require_pi_arm64
  if [ ! -x /usr/bin/ollama ] && [ -x /usr/local/bin/ollama ]; then
    ln -sf /usr/local/bin/ollama /usr/bin/ollama
  fi
  test -x /usr/bin/ollama
  if [ ! -f /etc/systemd/system/ollama.service ]; then
    write_ollama_service
  fi

  install -d -o root -g root -m 0755 /etc/systemd/system/ollama.service.d
  MEMORY_KIB="$(awk '/^MemTotal:/ { print $2 }' /proc/meminfo)"
  if [ "${MEMORY_KIB:-0}" -ge 14680064 ]; then
    CONTEXT_LENGTH=16384
  else
    CONTEXT_LENGTH=8192
  fi
  OVERRIDE_TMP="$(mktemp)"
  trap 'rm -f "$OVERRIDE_TMP"' EXIT HUP INT TERM
  printf '%s\n' \
    '[Service]' \
    'Environment="OLLAMA_HOST=127.0.0.1:11434"' \
    'Environment="OLLAMA_NO_CLOUD=1"' \
    'Environment="OLLAMA_MAX_LOADED_MODELS=1"' \
    'Environment="OLLAMA_NUM_PARALLEL=1"' \
    "Environment=\"OLLAMA_CONTEXT_LENGTH=$CONTEXT_LENGTH\"" > "$OVERRIDE_TMP"
  install -o root -g root -m 0644 "$OVERRIDE_TMP" /etc/systemd/system/ollama.service.d/10-loopback.conf
  rm -f "$OVERRIDE_TMP"
  trap - EXIT HUP INT TERM

  systemctl daemon-reload
  systemctl enable --now ollama.service

  ATTEMPT=0
  until curl --fail --silent --show-error http://127.0.0.1:11434/api/tags >/dev/null; do
    ATTEMPT=$((ATTEMPT + 1))
    if [ "$ATTEMPT" -ge 30 ]; then
      echo "Ollama did not become ready on its loopback address." >&2
      systemctl status --no-pager ollama.service || true
      exit 1
    fi
    sleep 1
  done
  echo "Ollama is running on 127.0.0.1:11434 with a $CONTEXT_LENGTH-token context."
}

case "$ACTION" in
  prepare-system) prepare_system ;;
  install-ollama-arm64) install_ollama_arm64 ;;
  configure-ollama-loopback) configure_ollama_loopback ;;
  *)
    echo "Action is not allowlisted: $ACTION" >&2
    exit 64
    ;;
esac
