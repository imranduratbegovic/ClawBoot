{
  "name": "clawboot",
  "version": "1.0.6",
  "author": "Imran Duratbegovic",
  "private": true,
  "overrides": {
    "postcss": "8.5.10"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "cross-env WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "node build.mjs",
    "start": "node setupd/index.mjs --static dist/client",
    "preview": "cross-env WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "start:setupd": "node setupd/index.mjs",
    "demo:setupd": "cross-env OPENCLAW_SETUP_DEMO=1 node setupd/index.mjs",
    "start:pi": "node setupd/index.mjs --static dist/client",
    "build:pi": "npm run build",
    "test": "npm run build && npm run test:setupd && node --test tests/rendered-html.test.mjs",
    "test:setupd": "node --test tests/setupd/*.test.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next"
  },
  "dependencies": {
    "next": "^16.2.10",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "cross-env": "^10.1.0",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13"
  },
  "type": "module"
}
